{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"type": "object",
	"required": ["name", "git", "versions"],
	"properties": {
		"name": {
			"type": "string"
		},
		"description": {
			"type": "string"
		},
		"license": {
			"type": "string"
		},
		"authors": {
			"type": "array",
			"items": { "type": "string" }
		},
		"git": {
			"type": "string",
			"format": "uri"
		},
		"branch": {
			"type": "string",
			"default": "main"
		},
		"versions": {
			"type": "object",
			"additionalProperties": {
				"type": "string",
				"description": "Commit hash for this version"
			},
			"minProperties": 1
		},
		"dependencies": {
			"type": "object",
			"additionalProperties": {
				"type": "string",
				"description": "Version constraint"
			}
		}
	},
	"additionalProperties": false
}
