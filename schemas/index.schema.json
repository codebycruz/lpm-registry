{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"type": "array",
	"items": {
		"type": "object",
		"required": ["name", "git", "latest"],
		"properties": {
			"name": {
				"type": "string"
			},
			"description": {
				"type": ["string", "null"]
			},
			"authors": {
				"type": "array",
				"items": { "type": "string" }
			},
			"latest": {
				"type": ["string", "null"]
			},
			"git": {
				"type": "string",
				"format": "uri"
			},
			"lastUpdated": {
				"type": ["string", "null"],
				"format": "date-time"
			}
		},
		"additionalProperties": false
	}
}
